generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  CLIENT
  LOST
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  niche     String
  city      String
  state     String
  email     String?
  website   String?
  score     Int        @default(50)
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
  @@index([city, state])
}

model AiActivityLog {
  id        String   @id @default(cuid())
  title     String
  detail    String
  createdAt DateTime @default(now())
}
